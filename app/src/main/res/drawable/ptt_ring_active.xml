<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outermost faint ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#33F44336" />
            <size android:width="340dp" android:height="340dp" />
        </shape>
    </item>
    <!-- Middle ring -->
    <item
        android:top="20dp"
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#66F44336" />
        </shape>
    </item>
    <!-- Inner ring (closest to button) - aligned with button border -->
    <item
        android:top="40dp"
        android:bottom="40dp"
        android:left="40dp"
        android:right="40dp">
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="#99F44336" />
        </shape>
    </item>
</layer-list>
